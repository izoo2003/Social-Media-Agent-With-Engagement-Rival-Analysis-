# ============================================
# Kafi Social Agent Frontend Environment File
# Copy to .env.local and customize
# ============================================

# API Configuration
# Local dev: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_VERSION=v1

# App Configuration
NEXT_PUBLIC_APP_NAME=Kafi Social Agent
NEXT_PUBLIC_APP_TITLE=Kafi Commodities - Social Media & Branding AI Agent

# Deployment mode
# full           → entire dashboard (senior / full deployment)
# creation-only  → Prompt Studio only (junior deployment)
NEXT_PUBLIC_APP_MODE=full

# Feature Flags (full mode only — ignored when NEXT_PUBLIC_APP_MODE=creation-only)
NEXT_PUBLIC_FEATURE_CALENDAR=true
NEXT_PUBLIC_FEATURE_ANALYTICS=true
NEXT_PUBLIC_FEATURE_QA=true
NEXT_PUBLIC_FEATURE_SCRAPER=true

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=
